NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/bkbs_db
# Persistent server (Railway): use pool 10. Vercel serverless keeps pool 1.
MONGODB_MAX_POOL_SIZE=10
MONGODB_BUFFER_TIMEOUT_MS=30000

# JWT Secrets
JWT_ACCESS_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_min_32_chars

# JWT Expiration
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Vercel Blob Storage (Production File Uploads)
# Get your token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# OCR service (local: npm run ocr:service | Railway: bundled in Dockerfile)
PADDLE_OCR_URL=http://127.0.0.1:8090
PADDLE_OCR_HOST=127.0.0.1
PADDLE_OCR_PORT=8090
PADDLE_OCR_TIMEOUT_MS=60000
# auto | paddle | rapidocr (use rapidocr in production)
PADDLE_OCR_ENGINE=rapidocr
# Limit parallel OCR calls from Node (protects other APIs on same host)
OCR_MAX_CONCURRENT=2
OCR_RATE_LIMIT_MAX=20
# Python OCR tuning
OCR_MAX_SIDE=1280
OCR_DET_LIMIT_SIDE_LEN=1280
OCR_USE_ANGLE_CLS=false
OCR_OMP_THREADS=2
